---
import BaseLayout from './BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DonateBand from '../components/DonateBand.astro';
import type { Article } from '../lib/types';
import { formatDateTime, readingTime } from '../lib/format';

interface Props {
  article: Article;
  sectionLabel: string;
  sectionHref: string;
}

const { article, sectionLabel, sectionHref } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.title,
  datePublished: article.date,
  author: { '@type': 'Person', name: article.author },
  publisher: { '@type': 'NewsMediaOrganization', name: 'Antiwar.com', url: 'https://www.antiwar.com' },
  mainEntityOfPage: article.url,
  ...(article.image ? { image: [article.image] } : {}),
  ...(article.tags.length ? { keywords: article.tags.join(', ') } : {}),
};
---

<BaseLayout
  title={`${article.title} — Antiwar.com`}
  description={article.excerpt}
  ogType="article"
  ogImage={article.image}
  jsonLd={jsonLd}
>
  <Masthead />

  <main id="main">
    <article class="article container" data-pagefind-body>
      <header class="article-header">
        <p class="crumb">
          <a href={sectionHref}>{sectionLabel}</a>
        </p>
        <h1>{article.title}</h1>
        <p class="byline">
          <span class="author">{article.author}</span>
          <span class="dot" aria-hidden="true">·</span>
          <time datetime={article.date}>{formatDateTime(article.date)}</time>
          {
            article.contentHtml && (
              <>
                <span class="dot" aria-hidden="true">·</span>
                <span>{readingTime(article.contentHtml)}</span>
              </>
            )
          }
        </p>
      </header>

      {
        article.image && (
          <figure class="article-media">
            <img src={article.image} alt="" width="1200" height="675" fetchpriority="high" />
          </figure>
        )
      }

      <div class="article-body" set:html={article.contentHtml} />

      <footer class="article-footer">
        {
          article.tags.length > 0 && (
            <ul class="tags" aria-label="Topics">
              {article.tags.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          )
        }
        <p class="origin">
          Originally published at <a href={article.url} rel="external">{new URL(article.url).hostname}</a>.
          Reprinted per Antiwar.com&rsquo;s
          <a href="https://www.antiwar.com/reprint.php" rel="external">reprint policy</a>.
        </p>
        <DonateBand compact />
      </footer>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    padding-block: var(--sp-8) 0;
  }

  .article {
    max-width: var(--measure);
  }

  .crumb {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--sp-3);
  }

  .crumb a {
    color: var(--brand);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .byline {
    margin-top: var(--sp-4);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-2);
  }

  .author {
    font-weight: 600;
    color: var(--ink);
  }

  .dot {
    margin-inline: var(--sp-1);
  }

  .article-media {
    margin-block: var(--sp-6);
  }

  .article-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    display: block;
  }

  .article-body {
    margin-top: var(--sp-6);
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: 1.65;
  }

  .article-body :global(p) {
    margin-bottom: var(--sp-4);
  }

  .article-body :global(a) {
    color: var(--brand);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .article-body :global(a:hover) {
    color: var(--brand-press);
  }

  .article-body :global(blockquote) {
    margin-block: var(--sp-6);
    padding-left: var(--sp-4);
    border-left: 3px solid var(--brand);
    color: var(--ink-2);
    font-style: italic;
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .article-body :global(h2),
  .article-body :global(h3) {
    font-family: var(--font-serif);
    margin-block: var(--sp-6) var(--sp-3);
    line-height: 1.2;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: var(--sp-4);
    padding-left: var(--sp-6);
  }

  .article-body :global(li) {
    margin-bottom: var(--sp-2);
  }

  .article-body :global(iframe) {
    max-width: 100%;
  }

  .article-footer {
    margin-top: var(--sp-8);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--rule);
    display: grid;
    gap: var(--sp-6);
  }

  .tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .tags li {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--ink-2);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: var(--sp-1) var(--sp-3);
    background: var(--surface);
  }

  .origin {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .origin a {
    text-decoration: underline;
  }
</style>
