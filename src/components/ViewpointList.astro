---
import type { Viewpoint } from '../lib/types';

interface Props {
  items: Viewpoint[];
}

const { items } = Astro.props;
---

<ul class="viewpoints">
  {
    items.map((v) => (
      <li>
        <a href={v.url} rel="external">{v.title}</a>
        <p class="meta">
          <span class="author">{v.author}</span>
          {v.sourceLabel && (
            <>
              <span class="dot" aria-hidden="true">·</span>
              <span class="source">{v.sourceLabel}</span>
            </>
          )}
          <span class="dot" aria-hidden="true">·</span>
          <span>{v.date}</span>
        </p>
      </li>
    ))
  }
</ul>

<style>
  .viewpoints {
    list-style: none;
    padding: 0;
  }

  li {
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--rule);
  }

  li:last-child {
    border-bottom: none;
  }

  li > a {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  li > a:hover {
    color: var(--brand);
  }

  .meta {
    margin-top: var(--sp-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .author {
    font-weight: 600;
  }

  .source {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.6875rem;
  }

  .dot {
    margin-inline: var(--sp-1);
  }
</style>
