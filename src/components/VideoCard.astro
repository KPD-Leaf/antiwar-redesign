---
import type { LatestVideo } from '../lib/loaders';
import { DECAMP_CHANNEL_URL } from '../lib/loaders';

interface Props {
  video: LatestVideo | null;
}

const { video } = Astro.props;
---

<a class="video-card" href={video?.url ?? DECAMP_CHANNEL_URL} rel="external">
  {
    video && (
      <span class="thumb">
        <img src={video.thumbnail} alt="" loading="lazy" width="480" height="270" />
        <span class="play" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5.5v13l11-6.5z" />
          </svg>
        </span>
      </span>
    )
  }
  <span class="video-title">
    {video ? video.title : 'Daily news broadcast with Antiwar.com news editor Dave DeCamp'}
  </span>
  <span class="video-meta">Watch on YouTube &rarr;</span>
</a>

<style>
  .video-card {
    display: block;
  }

  .thumb {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--rule);
    margin-bottom: var(--sp-2);
  }

  .thumb img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }

  .play svg {
    box-sizing: content-box;
    padding: 10px 12px;
    border-radius: 50%;
    background: rgb(0 0 0 / 0.65);
    color: #fff;
  }

  .video-card:hover .play svg {
    background: var(--brand);
  }

  .video-title {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  .video-card:hover .video-title {
    color: var(--brand);
  }

  .video-meta {
    display: block;
    margin-top: var(--sp-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--ink-2);
  }
</style>
