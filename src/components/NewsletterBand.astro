---
import { withBase } from '../lib/url';
---

<aside class="newsletter" aria-label="Newsletter signup">
  <p class="nl-head">The week in nonintervention, in your inbox</p>
  <p class="nl-sub">Get the Antiwar.com newsletter — headlines, original analysis, and viewpoints.</p>
  <a class="nl-cta" href={withBase('/newsletter')}>Sign up free &rarr;</a>
</aside>

<style>
  .newsletter {
    border: 1px solid var(--rule);
    border-top: 3px solid var(--brand);
    border-radius: var(--radius);
    background: var(--surface);
    padding: var(--sp-4);
  }

  .nl-head {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 700;
    line-height: 1.25;
  }

  .nl-sub {
    margin-top: var(--sp-2);
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--ink-2);
  }

  .nl-cta {
    display: inline-block;
    margin-top: var(--sp-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--brand);
  }

  .nl-cta:hover {
    color: var(--brand-press);
  }
</style>
