---
import type { Article } from '../lib/types';
import { formatDateTime, readingTime } from '../lib/format';
import { withBase } from '../lib/url';

interface Props {
  article: Article;
}

const { article } = Astro.props;
const href = article.source === 'original' ? article.url : withBase(`/${article.source}/${article.slug}`);
---

<article class="lead">
  {
    article.image && (
      <a class="lead-media" href={href} tabindex="-1" aria-hidden="true">
        <img src={article.image} alt="" loading="eager" fetchpriority="high" width="1200" height="675" />
      </a>
    )
  }
  <div class="lead-body">
    <p class="kicker">Top Story</p>
    <h2 class="lead-title">
      <a href={href}>{article.title}</a>
    </h2>
    <p class="lead-excerpt">{article.excerpt}</p>
    <p class="meta">
      <span class="author">{article.author}</span>
      <span class="dot" aria-hidden="true">·</span>
      <time datetime={article.date}>{formatDateTime(article.date)}</time>
      {
        article.contentHtml && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span>{readingTime(article.contentHtml)}</span>
          </>
        )
      }
    </p>
  </div>
</article>

<style>
  .lead-media {
    display: block;
    margin-bottom: var(--sp-4);
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--rule);
  }

  .lead-media img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand);
    margin-bottom: var(--sp-2);
  }

  .lead-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .lead-title a:hover {
    color: var(--brand);
  }

  .lead-excerpt {
    margin-top: var(--sp-3);
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 60ch;
  }

  .meta {
    margin-top: var(--sp-3);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .author {
    font-weight: 600;
    color: var(--ink-2);
  }

  .dot {
    margin-inline: var(--sp-1);
  }
</style>
