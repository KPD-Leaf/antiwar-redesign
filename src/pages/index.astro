---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LeadStory from '../components/LeadStory.astro';
import FeatureCard from '../components/FeatureCard.astro';
import RiverList from '../components/RiverList.astro';
import ViewpointList from '../components/ViewpointList.astro';
import DonateBand from '../components/DonateBand.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import VideoCard from '../components/VideoCard.astro';
import RegionGrid from '../components/RegionGrid.astro';
import { loadContent, loadHortonEpisodes, loadLatestVideo, originalSlug } from '../lib/loaders';
import { formatDate } from '../lib/format';
import { withBase } from '../lib/url';

const { news, blog, original, originalExtras, river, viewpoints, regions, columnists } = await loadContent();
const video = await loadLatestVideo();
const hortonEpisodes = await loadHortonEpisodes();

// Top Story selection.
// Default is algorithmic: the latest article from news.antiwar.com.
// Editors: to hand-pick the lead, set LEAD_SLUG to a news post slug, e.g.
//   const LEAD_SLUG = 'cafe-bombing-in-damascus-kills-at-least-9-wounds-20';
// If the slug isn't in the current feed, the algorithmic pick is used.
const LEAD_SLUG: string | null = null;

const editorialIdx = LEAD_SLUG ? news.findIndex((a) => a.slug === LEAD_SLUG) : -1;
const leadIdx = editorialIdx !== -1 ? editorialIdx : 0;
const lead = news[leadIdx];
const restNews = news.filter((_, i) => i !== leadIdx);
const secondary = restNews.slice(0, 2);
const headlines = restNews.slice(2, 13); // the next 11 news.antiwar.com stories

const opinion = original.slice(0, 4);
const blogFeatures = blog.slice(0, 3);

// original.antiwar.com articles we host as local pages (full-body scrape succeeded)
const localOpinionSlugs = new Set(
  [...original, ...originalExtras].filter((a) => a.contentHtml).map((a) => a.slug),
);
const opinionHref = (url: string) =>
  localOpinionSlugs.has(originalSlug(url)) ? withBase(`/original/${originalSlug(url)}`) : url;
const opinionRel = (url: string) => (localOpinionSlugs.has(originalSlug(url)) ? undefined : 'external');

// The homepage rail mirrors antiwar.com's "top" columnists group
const featuredColumnists = columnists.filter((c) => c.tier === 'featured');
---

<BaseLayout
  title="Antiwar.com — News, Viewpoints, and Activities"
  description="Your best source for antiwar news, viewpoints, and activities. Opposing war and promoting a noninterventionist foreign policy since 1995."
  ogImage={lead?.image}
>
  <Masthead />

  <main id="main">
    <div class="container">
      <h1 class="visually-hidden">Antiwar.com — antiwar news, viewpoints, and activities</h1>
      <div class="home-grid">
        <section class="zone-lead" aria-label="Top stories">
          {lead && <LeadStory article={lead} />}
          <div class="secondary">
            {secondary.map((a) => <FeatureCard article={a} showImage={false} />)}
          </div>
        </section>

        <section class="zone-river" aria-label="News">
          <SectionHeader title="News" href="/news" linkLabel="All News" />
          <ul class="compact-list">
            {
              headlines.map((a) => (
                <li>
                  <a href={withBase(`/news/${a.slug}`)}>{a.title}</a>
                  <p class="compact-meta">
                    <span class="compact-author">{a.author}</span>
                    <span aria-hidden="true"> · </span>
                    <time datetime={a.date}>{formatDate(a.date)}</time>
                  </p>
                </li>
              ))
            }
          </ul>
        </section>

        <aside class="zone-rail">
          <section aria-label="Opinion">
            <SectionHeader title="Opinion" href="/original" />
            <ul class="rail-list">
              {
                opinion.map((a) => (
                  <li>
                    <a href={opinionHref(a.url)} rel={opinionRel(a.url)}>{a.title}</a>
                    <p class="compact-meta">
                      <span class="compact-author">{a.author}</span>
                      <span aria-hidden="true"> · </span>
                      <time datetime={a.date}>{formatDate(a.date)}</time>
                    </p>
                  </li>
                ))
              }
            </ul>
          </section>

          <section aria-label="Antiwar News With Dave DeCamp">
            <SectionHeader title="Antiwar News With Dave DeCamp" />
            <VideoCard video={video} />
          </section>

          <section aria-label="The Scott Horton Show">
            <SectionHeader title="The Scott Horton Show" />
            {
              hortonEpisodes && (
                <ul class="rail-list">
                  {hortonEpisodes.map((ep) => (
                    <li>
                      <a href={ep.url} rel="external">{ep.title}</a>
                      {ep.dateLabel && <p class="compact-meta">{ep.dateLabel}</p>}
                    </li>
                  ))}
                </ul>
              )
            }
            <p class="horton">
              Foreign-policy interviews with journalists, scholars, and policymakers, hosted by
              Antiwar.com editorial director Scott Horton.
              <a href="https://scotthorton.org/" rel="external">Listen at scotthorton.org &rarr;</a>
            </p>
          </section>

          <NewsletterBand />
        </aside>
      </div>

      <div class="band-slot">
        <DonateBand />
      </div>

      <section aria-label="The Antiwar.com Blog">
        <SectionHeader title="The Antiwar.com Blog" href="/blog" />
        <div class="card-row">
          {blogFeatures.map((a) => <FeatureCard article={a} kicker="Blog" />)}
        </div>
      </section>

      <div class="two-col">
        <section aria-label="More news">
          <SectionHeader title="More News" href="/news" linkLabel="View all" />
          <RiverList groups={river} limit={12} />
        </section>

        <section aria-label="Viewpoints">
          <SectionHeader title="Viewpoints" href="/viewpoints" />
          <ViewpointList items={viewpoints.slice(0, 8)} />
        </section>
      </div>

      {
        regions.length > 0 && (
          <div class="world-grid">
            <section aria-label="Regional news">
              <SectionHeader title="Regional News" href="/regions" linkLabel="All regions" />
              <RegionGrid regions={regions} />
            </section>

            {featuredColumnists.length > 0 && (
              <aside aria-label="Columnists">
                <SectionHeader title="Columnists" href="/columnists" />
                <ul class="columnist-list">
                  {featuredColumnists.map((c) => (
                    <li>
                      <a class="columnist-name" href={c.url} rel="external">
                        {c.name}
                      </a>
                      {c.latestTitle && c.latestUrl && (
                        <a class="columnist-latest" href={opinionHref(c.latestUrl)} rel={opinionRel(c.latestUrl)}>
                          {c.latestTitle}
                        </a>
                      )}
                    </li>
                  ))}
                </ul>
              </aside>
            )}
          </div>
        )
      }
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    padding-block: var(--sp-6) 0;
  }

  .home-grid {
    display: grid;
    grid-template-columns: 5fr 4fr 3fr;
    gap: var(--sp-8);
  }

  .zone-lead,
  .zone-river,
  .zone-rail {
    min-width: 0;
  }

  .zone-river {
    border-inline: 1px solid var(--rule);
    padding-inline: var(--sp-6);
  }

  .zone-rail {
    display: grid;
    gap: var(--sp-8);
    align-content: start;
  }

  .secondary {
    margin-top: var(--sp-6);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--rule);
    display: grid;
    gap: var(--sp-4);
  }

  .secondary > :global(* + *) {
    padding-top: var(--sp-4);
    border-top: 1px solid var(--rule);
  }

  .band-slot {
    margin-block: var(--sp-12);
  }

  .card-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .two-col {
    margin-top: var(--sp-12);
    margin-bottom: var(--sp-4);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
  }

  .world-grid {
    margin-top: var(--sp-12);
    margin-bottom: var(--sp-4);
    display: grid;
    grid-template-columns: 9fr 3fr;
    gap: var(--sp-8);
  }

  .world-grid > * {
    min-width: 0;
  }

  .columnist-list {
    list-style: none;
    padding: 0;
  }

  .columnist-list li {
    padding-block: var(--sp-2);
    border-bottom: 1px solid var(--rule);
  }

  .columnist-list li:last-child {
    border-bottom: none;
  }

  .columnist-name {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-2);
  }

  .columnist-name:hover {
    color: var(--brand);
  }

  .columnist-latest {
    display: block;
    margin-top: 2px;
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1.35;
  }

  .columnist-latest:hover {
    color: var(--brand);
  }

  .compact-list {
    list-style: none;
    padding: 0;
  }

  .compact-list li {
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--rule);
  }

  .compact-list li:last-child {
    border-bottom: none;
  }

  .compact-list li > a {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  .compact-list li > a:hover {
    color: var(--brand);
  }

  .compact-meta {
    margin-top: var(--sp-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .compact-author {
    font-weight: 600;
  }

  .rail-list {
    list-style: none;
    padding: 0;
  }

  .rail-list li {
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--rule);
  }

  .rail-list li:first-child {
    padding-top: 0;
  }

  .rail-list li:last-child {
    border-bottom: none;
  }

  .rail-list li > a {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  .rail-list li > a:hover {
    color: var(--brand);
  }

  .horton {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--ink-2);
  }

  .rail-list + .horton {
    margin-top: var(--sp-2);
    padding-top: var(--sp-3);
    border-top: 1px solid var(--rule);
  }

  .horton a {
    display: block;
    margin-top: var(--sp-2);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--ink);
  }

  .horton a:hover {
    color: var(--brand);
  }

  @media (max-width: 1023px) {
    .home-grid {
      grid-template-columns: 1fr 1fr;
    }

    .zone-lead {
      grid-column: 1 / -1;
    }

    .zone-river {
      border-inline: none;
      padding-inline: 0;
    }

    .card-row {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
  }

  @media (max-width: 767px) {
    .home-grid,
    .two-col,
    .world-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
