---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LeadStory from '../components/LeadStory.astro';
import FeatureCard from '../components/FeatureCard.astro';
import RiverList from '../components/RiverList.astro';
import ViewpointList from '../components/ViewpointList.astro';
import DonateBand from '../components/DonateBand.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import { loadContent } from '../lib/loaders';
import { formatDate } from '../lib/format';
import { withBase } from '../lib/url';

const { news, blog, original, river, viewpoints } = await loadContent();

// Lead = newest news article that has an image; the rest flow in order.
const leadIdx = Math.max(0, news.findIndex((a) => a.image));
const lead = news[leadIdx];
const restNews = news.filter((_, i) => i !== leadIdx);
const secondary = restNews.slice(0, 2);
const moreNews = restNews.slice(2, 10);

const originalFeatures = original.slice(0, 3);
const blogLead = blog[0];
const blogMore = blog.slice(1, 6);
---

<BaseLayout
  title="Antiwar.com — News, Viewpoints, and Activities"
  description="Your best source for antiwar news, viewpoints, and activities. Opposing war and promoting a noninterventionist foreign policy since 1995."
  ogImage={lead?.image}
>
  <Masthead />

  <main id="main">
    <div class="container">
      <h1 class="visually-hidden">Antiwar.com — antiwar news, viewpoints, and activities</h1>
      <div class="home-grid">
        <section class="zone-lead" aria-label="Top stories">
          {lead && <LeadStory article={lead} />}
          <div class="secondary">
            {secondary.map((a) => <FeatureCard article={a} showImage={false} />)}
          </div>
        </section>

        <section class="zone-river" aria-label="Latest headlines">
          <SectionHeader title="Latest Headlines" href="/news" linkLabel="All headlines" />
          <RiverList groups={river} limit={16} />
        </section>

        <aside class="zone-rail">
          <section aria-label="Viewpoints">
            <SectionHeader title="Viewpoints" href="/viewpoints" />
            <ViewpointList items={viewpoints.slice(0, 7)} />
          </section>
          <NewsletterBand />
        </aside>
      </div>

      <div class="band-slot">
        <DonateBand />
      </div>

      <section aria-label="Antiwar.com Original">
        <SectionHeader title="Antiwar.com Original" href="/original" />
        <div class="card-row">
          {originalFeatures.map((a) => <FeatureCard article={a} kicker="Original" />)}
        </div>
      </section>

      <div class="two-col">
        <section aria-label="More news">
          <SectionHeader title="More News" href="/news" />
          <ul class="compact-list">
            {
              moreNews.map((a) => (
                <li>
                  <a href={withBase(`/news/${a.slug}`)}>{a.title}</a>
                  <p class="compact-meta">
                    <span class="compact-author">{a.author}</span>
                    <span aria-hidden="true"> · </span>
                    <time datetime={a.date}>{formatDate(a.date)}</time>
                  </p>
                </li>
              ))
            }
          </ul>
        </section>

        <section aria-label="Blog">
          <SectionHeader title="The Antiwar.com Blog" href="/blog" />
          {blogLead && <FeatureCard article={blogLead} />}
          <ul class="compact-list blog-list">
            {
              blogMore.map((a) => (
                <li>
                  <a href={withBase(`/blog/${a.slug}`)}>{a.title}</a>
                  <p class="compact-meta">
                    <span class="compact-author">{a.author}</span>
                    <span aria-hidden="true"> · </span>
                    <time datetime={a.date}>{formatDate(a.date)}</time>
                  </p>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    padding-block: var(--sp-6) 0;
  }

  .home-grid {
    display: grid;
    grid-template-columns: 5fr 4fr 3fr;
    gap: var(--sp-8);
  }

  .zone-lead,
  .zone-river,
  .zone-rail {
    min-width: 0;
  }

  .zone-river {
    border-inline: 1px solid var(--rule);
    padding-inline: var(--sp-6);
  }

  .zone-rail {
    display: grid;
    gap: var(--sp-8);
    align-content: start;
  }

  .secondary {
    margin-top: var(--sp-6);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--rule);
    display: grid;
    gap: var(--sp-4);
  }

  .secondary > :global(* + *) {
    padding-top: var(--sp-4);
    border-top: 1px solid var(--rule);
  }

  .band-slot {
    margin-block: var(--sp-12);
  }

  .card-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .two-col {
    margin-top: var(--sp-12);
    margin-bottom: var(--sp-4);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
  }

  .compact-list {
    list-style: none;
    padding: 0;
  }

  .compact-list li {
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--rule);
  }

  .compact-list li:last-child {
    border-bottom: none;
  }

  .compact-list li > a {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  .compact-list li > a:hover {
    color: var(--brand);
  }

  .compact-meta {
    margin-top: var(--sp-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .compact-author {
    font-weight: 600;
  }

  .blog-list {
    margin-top: var(--sp-4);
    padding-top: var(--sp-2);
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 1023px) {
    .home-grid {
      grid-template-columns: 1fr 1fr;
    }

    .zone-lead {
      grid-column: 1 / -1;
    }

    .zone-river {
      border-inline: none;
      padding-inline: 0;
    }

    .card-row {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
  }

  @media (max-width: 767px) {
    .home-grid,
    .two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
