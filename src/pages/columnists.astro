---
import SectionLayout from '../layouts/SectionLayout.astro';
import { loadContent, originalSlug } from '../lib/loaders';
import { withBase } from '../lib/url';

const { columnists, original, originalExtras } = await loadContent();

const localOpinionSlugs = new Set(
  [...original, ...originalExtras].filter((a) => a.contentHtml).map((a) => a.slug),
);
const opinionHref = (url: string) =>
  localOpinionSlugs.has(originalSlug(url)) ? withBase(`/original/${originalSlug(url)}`) : url;
const opinionRel = (url: string) => (localOpinionSlugs.has(originalSlug(url)) ? undefined : 'external');

const groups = [
  { heading: 'Columnists', list: columnists.filter((c) => c.tier === 'featured') },
  { heading: 'More Columnists', list: columnists.filter((c) => c.tier === 'regular') },
  { heading: 'Former Columnists', list: columnists.filter((c) => c.tier === 'former') },
].filter((g) => g.list.length > 0);
---

<SectionLayout
  title="Columnists — Antiwar.com"
  description="Antiwar.com's columnists and their latest exclusive opinion columns."
  heading="Columnists"
  intro="The writers behind Antiwar.com's exclusive columns and analysis, with each columnist's latest piece."
>
  {
    groups.map((group, i) => (
      <section class="group" aria-label={group.heading}>
        {i > 0 && <h2 class="group-heading">{group.heading}</h2>}
        <ul class="columnists">
          {group.list.map((c) => (
            <li>
              <a class="name" href={c.url} rel="external">
                {c.name}
              </a>
              {c.latestTitle && c.latestUrl && (
                <a class="latest" href={opinionHref(c.latestUrl)} rel={opinionRel(c.latestUrl)}>
                  {c.latestTitle}
                </a>
              )}
              {c.latestDate && <p class="date">{c.latestDate}</p>}
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</SectionLayout>

<style>
  .group {
    margin-bottom: var(--sp-10);
  }

  .group-heading {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: var(--sp-2);
    border-bottom: 2px solid var(--ink);
    margin-bottom: var(--sp-4);
  }

  .columnists {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4) var(--sp-8);
  }

  .columnists li {
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--rule);
  }

  .name {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-2);
  }

  .name:hover {
    color: var(--brand);
  }

  .latest {
    display: block;
    margin-top: var(--sp-1);
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
  }

  .latest:hover {
    color: var(--brand);
  }

  .date {
    margin-top: var(--sp-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  @media (max-width: 1023px) {
    .columnists {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 639px) {
    .columnists {
      grid-template-columns: 1fr;
    }
  }
</style>
